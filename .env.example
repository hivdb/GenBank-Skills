OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# Optional HCV pipeline defaults loaded by:
# - hcv-ns3-build-workflow/scripts/run_ns3_pipeline.sh
# - hcv-ns5a-build-workflow/scripts/run_ns5a_pipeline.sh
# - hcv-ns5b-build-workflow/scripts/run_ns5b_pipeline.sh
#
# Keep this file in the repository root. Values here override
# pipeline.local.toml defaults when both are present.
#
# EXCEL_FILE=/absolute/path/to/HCV_BlastHits.xlsx
# FASTA_POOL=/absolute/path/to/FASTA
# GENBANK_DIR=/absolute/path/to/genbank_seq_files
# SHEET_NAME=Ref_summary_20260429 (2)
# OUTPUT_DIR=outputs
# REFERENCE_FASTA=HCV_GT_RefSeqs.fasta
# SUBTYPE_JSON=HCV_Subtype_Refs_By_Genome_NA.json
# GT_AA_JSON=HCV_GT_Refs_By_Gene_AA.json
# PYTHON_BIN=.venv/bin/python
# TEMP_ROOT=temp/run_ns3_pipeline

